{
  "schemaVersion": 1,
  "id": "pixelball",
  "version": "${version}",

  "name": "Pixelball",
  "description": "Connects a Tiltify campaign to in-game donation rewards, goals, and a server bossbar.",
  "authors": ["Cats1337"],
  "contact": {},

  "license": "All-Rights-Reserved",
  "icon": "assets/pixelball/icon.png",

  "environment": "server",
  "entrypoints": {
    "fabric-datagen": ["io.github.cats1337.pixelball.client.PixelballDataGenerator"],
    "main": ["io.github.cats1337.pixelball.Pixelball"]
  },

  "mixins": [
    "pixelball.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}",
    "fabric-permissions-api-v0": "*",
    "placeholder-api": "*"
  }
}
